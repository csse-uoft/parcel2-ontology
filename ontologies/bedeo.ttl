@prefix : <https://csse.utoronto.ca/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix bedeo: <https://csse.utoronto.ca/> .
@base <https://csse.utoronto.ca/> .

<https://csse.utoronto.ca/> rdf:type owl:Ontology ;
                             owl:imports <http://qudt.org/3.1.5/qudt-all> ,
                                         <http://www.w3.org/2006/time#2016> .

#################################################################
#    Annotation properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#altLabel
<http://www.w3.org/2004/02/skos/core#altLabel> rdf:type owl:AnnotationProperty .


###  https://csse.utoronto.ca/has_partner_type
bedeo:has_partner_type rdf:type owl:AnnotationProperty .


###  https://csse.utoronto.ca/has_partnership_role_required
bedeo:has_partnership_role_required rdf:type owl:AnnotationProperty .


###  https://csse.utoronto.ca/has_read
bedeo:has_read rdf:type owl:AnnotationProperty .


###  https://csse.utoronto.ca/has_site_address
bedeo:has_site_address rdf:type owl:AnnotationProperty .


###  https://csse.utoronto.ca/has_space_needs
bedeo:has_space_needs rdf:type owl:AnnotationProperty .


###  https://csse.utoronto.ca/has_username
bedeo:has_username rdf:type owl:AnnotationProperty .


###  https://csse.utoronto.ca/type
bedeo:type rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://qudt.org/schema/qudt/hasQuantityKind
<http://qudt.org/schema/qudt/hasQuantityKind> rdfs:subPropertyOf bedeo:has_characteristic_kind .


###  http://qudt.org/schema/qudt/quantityValue
<http://qudt.org/schema/qudt/quantityValue> rdfs:subPropertyOf bedeo:has_value .


###  https://csse.utoronto.ca/activates_role
bedeo:activates_role rdf:type owl:ObjectProperty ;
                     rdfs:domain bedeo:ContributionType ;
                     rdfs:range bedeo:Role ;
                     rdfs:comment "Identifies the Role that the ContributionType activates"@en ;
                     rdfs:label "Activates role"@en .


###  https://csse.utoronto.ca/component_of
bedeo:component_of rdf:type owl:ObjectProperty ;
                   rdfs:comment "Identifies the entity that the first entity is a component of"@en ;
                   rdfs:label "Component of"@en .


###  https://csse.utoronto.ca/current_land_use
bedeo:current_land_use rdf:type owl:ObjectProperty ;
                       rdfs:domain bedeo:Land ;
                       rdfs:range bedeo:LandUse ;
                       rdfs:comment "The current land use of the real property/land"@en ;
                       rdfs:label "Current land use" .


###  https://csse.utoronto.ca/designated_land_use
bedeo:designated_land_use rdf:type owl:ObjectProperty ;
                          rdfs:domain bedeo:Land ;
                          rdfs:range bedeo:LandUse ;
                          rdfs:comment "The land use that will be designated for the real property/land"@en ;
                          rdfs:label "Designated land use"@en .


###  https://csse.utoronto.ca/for_characteristic
bedeo:for_characteristic rdf:type owl:ObjectProperty ;
                         rdfs:domain bedeo:CharacteristicConstraintClause ;
                         rdfs:range <http://qudt.org/schema/qudt/QuantityKind> ;
                         rdfs:comment "Identifies the Quantity Kind for a Characteristic Constraint Clause (i.e., what characteristic is the constraint for?)."@en ;
                         rdfs:label "For characteristic"@en .


###  https://csse.utoronto.ca/for_class
bedeo:for_class rdf:type owl:ObjectProperty ;
                rdfs:domain bedeo:CharacteristicConstraintClause ;
                rdfs:range owl:Class ;
                rdfs:comment "Identifies the class for the Characteristic Constraint Clause (i.e., what class of entity is the constraint for?)"@en ;
                rdfs:label "For class"@en .


###  https://csse.utoronto.ca/for_partnership_opportunity
bedeo:for_partnership_opportunity rdf:type owl:ObjectProperty ;
                                  rdfs:range bedeo:PartnershipOpportunity ;
                                  rdfs:comment "Associates an entity with its corresponding Partnership Opportunity"@en ;
                                  rdfs:label "For partnership opportunity"@en .


###  https://csse.utoronto.ca/governed_by
bedeo:governed_by rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf owl:topObjectProperty ;
                  rdfs:domain bedeo:Zone ;
                  rdfs:range bedeo:Organization ;
                  rdfs:comment "Indicates the organization that is responsible for governing and regulating a zone"@en ;
                  rdfs:label "Governed by"@en .


###  https://csse.utoronto.ca/has_account
bedeo:has_account rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf owl:topObjectProperty ;
                  rdfs:domain bedeo:Organization ;
                  rdfs:range bedeo:Account ;
                  rdfs:comment "Identifies the account associated with an organization"@en ;
                  rdfs:label "Has account"@en .


###  https://csse.utoronto.ca/has_additional_info
bedeo:has_additional_info rdf:type owl:ObjectProperty ;
                          rdfs:domain bedeo:PartnershipOpportunity ;
                          rdfs:range bedeo:OpportunityAdditionalInfo ;
                          rdfs:comment "identifies the additional information associated with a Partnership Opportunity"@en ;
                          rdfs:label "Has additional info"@en .


###  https://csse.utoronto.ca/has_address
bedeo:has_address rdf:type owl:ObjectProperty ;
                  rdfs:range bedeo:Address ;
                  rdfs:comment "Identifies the Address of an entity"@en ;
                  rdfs:label "Has address"@en .


###  https://csse.utoronto.ca/has_application
bedeo:has_application rdf:type owl:ObjectProperty ;
                      rdfs:range bedeo:Application ;
                      rdfs:comment "Identifies the Application (i.e., application to participate in a partnership opportunity) associated with an entity"@en ;
                      rdfs:label "Has application"@en .


###  https://csse.utoronto.ca/has_area_unit
bedeo:has_area_unit rdf:type owl:ObjectProperty ;
                    rdfs:domain bedeo:Land ;
                    rdfs:label "Has area unit"@en ,
                               "Identifies the area unit used for the real property/land"@en .


###  https://csse.utoronto.ca/has_asset
bedeo:has_asset rdf:type owl:ObjectProperty ;
                rdfs:range bedeo:Asset ;
                rdfs:comment "Identifies an asset associated with an entity"@en ;
                rdfs:label "Has asset"@en .


###  https://csse.utoronto.ca/has_available_role_type
bedeo:has_available_role_type rdf:type owl:ObjectProperty ;
                              rdfs:range bedeo:RoleType ;
                              rdfs:comment "Identifies the role types that are available"@en ;
                              rdfs:label "Has available role type"@en .


###  https://csse.utoronto.ca/has_base_version
bedeo:has_base_version rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty .


###  https://csse.utoronto.ca/has_characteristic
bedeo:has_characteristic rdf:type owl:ObjectProperty ;
                         rdfs:range bedeo:Characteristic ;
                         rdfs:comment "Identifies a characteristic of the entity"@en ;
                         rdfs:label "Has characteristic"@en .


###  https://csse.utoronto.ca/has_characteristic_kind
bedeo:has_characteristic_kind rdf:type owl:ObjectProperty ;
                              rdfs:range bedeo:CharacteristicKind ;
                              rdfs:comment "Identifies the kind of characteristic associated with the entity"@en ;
                              rdfs:label "Has characteristic kind"@en .


###  https://csse.utoronto.ca/has_clause
bedeo:has_clause rdf:type owl:ObjectProperty ;
                 rdfs:domain bedeo:LogicalFormula ;
                 rdfs:range bedeo:LogicalFormula ;
                 rdfs:comment "Identifies a clause of a logical formula"@en ;
                 rdfs:label "Has clause"@en .


###  https://csse.utoronto.ca/has_co-applicant
bedeo:has_co-applicant rdf:type owl:ObjectProperty ;
                       rdfs:domain bedeo:Application ;
                       rdfs:range bedeo:Agent ;
                       rdfs:comment "Identifies a co-applicant of a partnership opportunity application"@en ;
                       rdfs:label "Has co-applicant"@en .


###  https://csse.utoronto.ca/has_component
bedeo:has_component rdf:type owl:ObjectProperty ;
                    rdfs:comment "Identifies a component of the entity"@en ;
                    rdfs:label "Has component"@en .


###  https://csse.utoronto.ca/has_constraint
bedeo:has_constraint rdf:type owl:ObjectProperty ;
                     rdfs:range bedeo:CharacteristicConstraintClause ;
                     rdfs:comment "Identifies a constraint associated with an entity"@en ;
                     rdfs:label "Has constraint"@en .


###  https://csse.utoronto.ca/has_contribution_type
bedeo:has_contribution_type rdf:type owl:ObjectProperty ;
                            rdfs:domain bedeo:Contribution ;
                            rdfs:range bedeo:ContributionType ;
                            rdfs:comment "Identifies the contribution type of the contribution"@en ;
                            rdfs:label "Has contribution type"@en .


###  https://csse.utoronto.ca/has_current_lessee
bedeo:has_current_lessee rdf:type owl:ObjectProperty ;
                         rdfs:range bedeo:Agent ;
                         rdfs:comment "Identifies the agent who is the current lessee"@en ;
                         rdfs:label "Has current lessee"@en .


###  https://csse.utoronto.ca/has_delivery_address
bedeo:has_delivery_address rdf:type owl:ObjectProperty ;
                           rdfs:domain bedeo:Organization ;
                           rdfs:range bedeo:Address ;
                           rdfs:comment "Identifies the deliver address of an organization"@en ;
                           rdfs:label "Has delivery address"@en .


###  https://csse.utoronto.ca/has_intended_opportunity
bedeo:has_intended_opportunity rdf:type owl:ObjectProperty ;
                               rdfs:domain bedeo:Notification ;
                               rdfs:range bedeo:PartnershipOpportunity ;
                               rdfs:comment "Identifies the partnership opportunity associated with a notification"@en ;
                               rdfs:label "Has intended opportunity"@en .


###  https://csse.utoronto.ca/has_interest_in
bedeo:has_interest_in rdf:type owl:ObjectProperty ;
                      rdfs:domain bedeo:Agent ;
                      rdfs:range bedeo:Asset ;
                      rdfs:comment "Identifies the asset than agent has interest in"@en ;
                      rdfs:label "Has interest in"@en .


###  https://csse.utoronto.ca/has_land
bedeo:has_land rdf:type owl:ObjectProperty ;
               rdfs:range bedeo:Land ;
               rdfs:comment "Identifies the land that is associated with an entity"@en ;
               rdfs:label "Has land"@en .


###  https://csse.utoronto.ca/has_latest_version
bedeo:has_latest_version rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf owl:topObjectProperty .


###  https://csse.utoronto.ca/has_legal_status
bedeo:has_legal_status rdf:type owl:ObjectProperty ;
                       rdfs:domain bedeo:Organization ;
                       rdfs:range bedeo:OrganizationLegalStatus ;
                       rdfs:comment "Indicates the legal status of the organization"@en ;
                       rdfs:label "Has legal status"@en .


###  https://csse.utoronto.ca/has_lessee
bedeo:has_lessee rdf:type owl:ObjectProperty ;
                 owl:inverseOf bedeo:leases ;
                 rdfs:domain bedeo:Asset ;
                 rdfs:range bedeo:Agent ;
                 rdfs:comment "Identifies the lessee of an asset"@en ;
                 rdfs:label "Has lessee"@en .


###  https://csse.utoronto.ca/has_location
bedeo:has_location rdf:type owl:ObjectProperty ;
                   rdfs:range bedeo:Location ;
                   rdfs:comment "Identifies the location associated with an entity"@en ;
                   rdfs:label "Has location"@en ;
                   <http://www.w3.org/2004/02/skos/core#altLabel> "Has site"@en .


###  https://csse.utoronto.ca/has_mailing_address
bedeo:has_mailing_address rdf:type owl:ObjectProperty ;
                          rdfs:domain bedeo:Organization ;
                          rdfs:range bedeo:Address ;
                          rdfs:comment "Identifies the mailing address of an organization"@en ;
                          rdfs:label "Has mailing address"@en .


###  https://csse.utoronto.ca/has_member
bedeo:has_member rdf:type owl:ObjectProperty ;
                 rdfs:domain bedeo:Organization ;
                 rdfs:range bedeo:Agent ;
                 rdfs:comment "Indicates the members who are part of an organization" ;
                 rdfs:label "Has member" .


###  https://csse.utoronto.ca/has_monetary_value
bedeo:has_monetary_value rdf:type owl:ObjectProperty ;
                         rdfs:range bedeo:Value ;
                         rdfs:comment "Indicates the monetary value of an entity"@en ;
                         rdfs:label "Has monetary value"@en .


###  https://csse.utoronto.ca/has_municipal_service
bedeo:has_municipal_service rdf:type owl:ObjectProperty ;
                            rdfs:range bedeo:Service ;
                            rdfs:comment "Indicates the municipal services of an entity"@en ;
                            rdfs:label "Has municipal service"@en .


###  https://csse.utoronto.ca/has_need_type
bedeo:has_need_type rdf:type owl:ObjectProperty ;
                    rdfs:range bedeo:PartnershipOpportunityNeedType ;
                    rdfs:comment "Indicates the partnership opportunity need type"@en ;
                    rdfs:label "Has need"@en .


###  https://csse.utoronto.ca/has_non_quantity_kind
bedeo:has_non_quantity_kind rdf:type owl:ObjectProperty ;
                            rdfs:subPropertyOf bedeo:has_characteristic_kind ;
                            rdfs:range bedeo:NonQuantityCharacteristicKind ;
                            rdfs:comment "Identifies the non quantity kind associated with the entity"@en ;
                            rdfs:label "Has non quantity kind"@en .


###  https://csse.utoronto.ca/has_notification
bedeo:has_notification rdf:type owl:ObjectProperty ;
                       rdfs:domain bedeo:PartnershipOpportunity ;
                       rdfs:range bedeo:Notification ;
                       rdfs:comment "Identifies the notifications associated with a partnership opportunity"@en ;
                       rdfs:label "Has notification"@en .


###  https://csse.utoronto.ca/has_object_value
bedeo:has_object_value rdf:type owl:ObjectProperty ;
                       rdfs:range bedeo:Value ;
                       rdfs:comment "Indicates the object value of an entity"@en ;
                       rdfs:label "Has object value"@en .


###  https://csse.utoronto.ca/has_operator
bedeo:has_operator rdf:type owl:ObjectProperty ;
                   rdfs:domain bedeo:CharacteristicConstraintClause ;
                   rdfs:range bedeo:Operator ;
                   rdfs:comment "Indicates the mathematical operator associated with a constraint"@en ;
                   rdfs:label "Has operator"@en .


###  https://csse.utoronto.ca/has_opportunity
bedeo:has_opportunity rdf:type owl:ObjectProperty ;
                      rdfs:domain bedeo:Organization ;
                      rdfs:range bedeo:PartnershipOpportunity ;
                      rdfs:comment "Identifies the opportunity associated with an organization"@en ;
                      rdfs:label "Has opportunity"@en .


###  https://csse.utoronto.ca/has_organization
bedeo:has_organization rdf:type owl:ObjectProperty ;
                       rdfs:range bedeo:Organization ;
                       rdfs:comment "Identifies the organization associated with an entity"@en ;
                       rdfs:label "Has organization"@en .


###  https://csse.utoronto.ca/has_organization_legal_name
bedeo:has_organization_legal_name rdf:type owl:ObjectProperty ;
                                  rdfs:domain bedeo:Organization ;
                                  rdfs:range bedeo:OrganizationLegalName ;
                                  rdfs:comment "Identifies the legal name of an organization"@en ;
                                  rdfs:label "Has organization legal name"@en .


###  https://csse.utoronto.ca/has_organization_registration_number
bedeo:has_organization_registration_number rdf:type owl:ObjectProperty ;
                                           rdfs:domain bedeo:Organization ;
                                           rdfs:range bedeo:OrganizationRegistrationNumber ;
                                           rdfs:comment "The unique identifier assigned to the organization upon registration."@en ;
                                           rdfs:label "Has organization business registration number"@en .


###  https://csse.utoronto.ca/has_organization_trade_name
bedeo:has_organization_trade_name rdf:type owl:ObjectProperty ;
                                  rdfs:domain bedeo:Organization ;
                                  rdfs:range bedeo:OrganizationTradeName ;
                                  rdfs:comment "Identifies the trade name of an organization"@en ;
                                  rdfs:label "Has organization trade name"@en .


###  https://csse.utoronto.ca/has_organization_type
bedeo:has_organization_type rdf:type owl:ObjectProperty ;
                            rdfs:domain bedeo:Organization ;
                            rdfs:range bedeo:OrganizationType ;
                            rdfs:comment "Identifies the organization type of the organization"@en ;
                            rdfs:label "Has organization type"@en .


###  https://csse.utoronto.ca/has_owner
bedeo:has_owner rdf:type owl:ObjectProperty ;
                owl:inverseOf bedeo:owns ;
                rdfs:range bedeo:Agent ;
                rdfs:comment "Identifies the owner of an entity"@en ;
                rdfs:label "Has owner"@en .


###  https://csse.utoronto.ca/has_part
bedeo:has_part rdf:type owl:ObjectProperty ,
                        owl:TransitiveProperty ;
               rdfs:comment "Identifies an entity that has another entity as a part of it"@en ;
               rdfs:label "Has part"@en .


###  https://csse.utoronto.ca/has_partner
bedeo:has_partner rdf:type owl:ObjectProperty ;
                  rdfs:domain bedeo:PartnershipOpportunity ;
                  rdfs:range bedeo:Agent ;
                  rdfs:comment "Identifies a partner of a partnership opportunity"@en ;
                  rdfs:label "Has partner"@en .


###  https://csse.utoronto.ca/has_preference
bedeo:has_preference rdf:type owl:ObjectProperty ;
                     rdfs:range bedeo:CharacteristicConstraintClause ;
                     rdfs:comment "Identifies a preference for a certain characteristic"@en ;
                     rdfs:label "Has preference"@en .


###  https://csse.utoronto.ca/has_primary_address
bedeo:has_primary_address rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf bedeo:has_address ;
                          rdfs:range bedeo:Address ;
                          rdfs:label "Has primary address"@en .


###  https://csse.utoronto.ca/has_primary_contact
bedeo:has_primary_contact rdf:type owl:ObjectProperty ;
                          rdfs:domain bedeo:PartnershipOpportunity ,
                                      [ rdf:type owl:Class ;
                                        owl:unionOf ( bedeo:Account
                                                      bedeo:Agent
                                                      bedeo:PartnershipOpportunity
                                                    )
                                      ] ;
                          rdfs:range bedeo:Contact ;
                          rdfs:comment "Identifies the primary contact for an account, agent, or partnership opportunity"@en ;
                          rdfs:label "Has primary contact"@en .


###  https://csse.utoronto.ca/has_principal_applicant
bedeo:has_principal_applicant rdf:type owl:ObjectProperty ;
                              rdfs:domain bedeo:Application ;
                              rdfs:range bedeo:Agent ;
                              rdfs:comment "Identifies the principal applicant of an application"@en ;
                              rdfs:label "Has prinicipal applicant"@en .


###  https://csse.utoronto.ca/has_project
bedeo:has_project rdf:type owl:ObjectProperty ;
                  rdfs:range bedeo:Project ;
                  rdfs:comment "Identifies a project associated with an entity"@en ;
                  rdfs:label "Has project"@en .


###  https://csse.utoronto.ca/has_project_stage
bedeo:has_project_stage rdf:type owl:ObjectProperty ;
                        rdfs:domain bedeo:Project ;
                        rdfs:range bedeo:ProjectStage ;
                        rdfs:label "Has project stage"@en ,
                                   "Indicates the current stage of the project"@en .


###  https://csse.utoronto.ca/has_project_type
bedeo:has_project_type rdf:type owl:ObjectProperty ;
                       rdfs:domain bedeo:Project ;
                       rdfs:range bedeo:ProjectType ;
                       rdfs:comment "Indicates the type of the project"@en ;
                       rdfs:label "Has project type"@en .


###  https://csse.utoronto.ca/has_proposal
bedeo:has_proposal rdf:type owl:ObjectProperty ;
                   rdfs:domain bedeo:Application ;
                   rdfs:range bedeo:Proposal ;
                   rdfs:comment "Identifies the proposal associated with an application"@en ;
                   rdfs:label "Has proposal"@en .


###  https://csse.utoronto.ca/has_proposed_zoning
bedeo:has_proposed_zoning rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf owl:topObjectProperty ;
                          rdfs:domain bedeo:real_estate_asset ;
                          rdfs:range bedeo:Zone ;
                          rdfs:comment "Indicates the proposed zoning for a real estate asset"@en ;
                          rdfs:label "Has proposed zoning"@en .


###  https://csse.utoronto.ca/has_real_estate_asset
bedeo:has_real_estate_asset rdf:type owl:ObjectProperty ;
                            rdfs:subPropertyOf bedeo:has_asset ;
                            rdfs:range bedeo:real_estate_asset ;
                            rdfs:comment "Identifies the real estate asset associated with an entity"@en ;
                            rdfs:label "Has real estate asset"@en .


###  https://csse.utoronto.ca/has_recipient
bedeo:has_recipient rdf:type owl:ObjectProperty ;
                    rdfs:domain bedeo:Notification ;
                    rdfs:range bedeo:Account ;
                    rdfs:comment "Identifies the recipient of a chat message"@en ;
                    rdfs:label "Has recipient"@en .


###  https://csse.utoronto.ca/has_role
bedeo:has_role rdf:type owl:ObjectProperty ;
               rdfs:domain bedeo:Agent ;
               rdfs:range bedeo:Role ;
               rdfs:comment "Identifies the role of an agent"@en ;
               rdfs:label "Has role"@en .


###  https://csse.utoronto.ca/has_role_type
bedeo:has_role_type rdf:type owl:ObjectProperty ;
                    rdfs:domain bedeo:Role ;
                    rdfs:range bedeo:RoleType ;
                    rdfs:comment "Identifies the role type of a specified role"@en ;
                    rdfs:label "Has role type"@en .


###  https://csse.utoronto.ca/has_sender
bedeo:has_sender rdf:type owl:ObjectProperty ;
                 rdfs:domain bedeo:Notification ;
                 rdfs:range bedeo:Account ;
                 rdfs:comment "Identifies the sender of a chat message"@en ;
                 rdfs:label "Has sender"@en .


###  https://csse.utoronto.ca/has_spatial_geometry
bedeo:has_spatial_geometry rdf:type owl:ObjectProperty ;
                           rdfs:domain bedeo:SpatialRepresentation ;
                           rdfs:range bedeo:SpatialGeometry ;
                           rdfs:comment "Links a geospatial representation of an entity to a spatial geometry"@en ;
                           rdfs:label "Has spatial geometry"@en .


###  https://csse.utoronto.ca/has_spatial_representation
bedeo:has_spatial_representation rdf:type owl:ObjectProperty ;
                                 rdfs:range bedeo:SpatialRepresentation ;
                                 rdfs:comment "Links an entity to a geospatial representation of the entity"@en ;
                                 rdfs:label "Has spatial representation"@en .


###  https://csse.utoronto.ca/has_type
bedeo:has_type rdf:type owl:ObjectProperty ;
               rdfs:range bedeo:Type ;
               rdfs:comment "Identifies the type of the entity"@en ;
               rdfs:label "Has type"@en .


###  https://csse.utoronto.ca/has_user
bedeo:has_user rdf:type owl:ObjectProperty ;
               owl:inverseOf bedeo:uses ;
               rdfs:domain bedeo:Asset ;
               rdfs:range bedeo:Agent ;
               rdfs:comment "Identifies the user of an asset"@en ;
               rdfs:label "Has user"@en .


###  https://csse.utoronto.ca/has_value
bedeo:has_value rdf:type owl:ObjectProperty ;
                rdfs:range bedeo:Value .


###  https://csse.utoronto.ca/has_version
bedeo:has_version rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf owl:topObjectProperty .


###  https://csse.utoronto.ca/has_zoning
bedeo:has_zoning rdf:type owl:ObjectProperty ;
                 rdfs:domain bedeo:real_estate_asset ;
                 rdfs:range bedeo:Zone ;
                 rdfs:comment "Indicates the zoning for a real estate asset"@en ;
                 rdfs:label "Has zoning"@en .


###  https://csse.utoronto.ca/isAKindOf
bedeo:isAKindOf rdf:type owl:ObjectProperty ,
                         owl:AsymmetricProperty ,
                         owl:TransitiveProperty ,
                         owl:IrreflexiveProperty ;
                rdfs:comment "An object property for defining hierarchies amongst individuals/instances"@en ;
                rdfs:label "Is a kind of"@en .


###  https://csse.utoronto.ca/is_account_of
bedeo:is_account_of rdf:type owl:ObjectProperty ;
                    rdfs:domain bedeo:Account ;
                    rdfs:range bedeo:Organization ;
                    rdfs:comment "Identifies the organization associated with an account"@en ;
                    rdfs:label "Is account of"@en .


###  https://csse.utoronto.ca/is_beneficiary_of
bedeo:is_beneficiary_of rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf bedeo:has_interest_in ;
                        rdfs:domain bedeo:Agent ;
                        rdfs:range bedeo:Asset ;
                        rdfs:comment "Identifies the asset than an agent is a beneficiary of"@en ;
                        rdfs:label "Is beneficiary of"@en .


###  https://csse.utoronto.ca/is_member_of
bedeo:is_member_of rdf:type owl:ObjectProperty ;
                   rdfs:domain bedeo:Agent ;
