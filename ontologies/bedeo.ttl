###  https://csse.utoronto.ca/is_searchable
bedeo:is_searchable rdf:type owl:DatatypeProperty ;
                    rdfs:domain bedeo:OpportunityAdditionalInfo ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Indicates whether the additional information is searchable"@en ;
                    rdfs:label "Is searchable"@en .


###  https://csse.utoronto.ca/is_tangible
bedeo:is_tangible rdf:type owl:DatatypeProperty ;
                  rdfs:domain bedeo:Asset ;
                  rdfs:range xsd:boolean ;
                  rdfs:comment "Indicates whether an asset has a physical existence"@en ;
                  rdfs:label "Is tangible"@en .


###  https://csse.utoronto.ca/is_vacant
bedeo:is_vacant rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf owl:topDataProperty ;
                rdfs:domain bedeo:real_estate_asset ;
                rdfs:range xsd:boolean ;
                rdfs:comment "Indicates whether a real estate asset is vacant or not.  Note that there are many different interpretations of the term “vacant.” For example, in some cases, vacant could refer to completely undeveloped land, while in other cases, vacant could refer to mostly undeveloped land but may include some minor structures or improvements.  For the purposes of this ontology, this property is only used to represent whether the real estate asset is asserted to be vacant or not."@en ;
                rdfs:label "Is vacant"@en .


#################################################################
#    Classes
#################################################################

###  http://qudt.org/schema/qudt/AbstractQuantityKind
<http://qudt.org/schema/qudt/AbstractQuantityKind> rdfs:subClassOf bedeo:CharacteristicKind .


###  http://qudt.org/schema/qudt/Quantity
<http://qudt.org/schema/qudt/Quantity> rdfs:subClassOf bedeo:Characteristic .


###  http://qudt.org/schema/qudt/QuantityValue
<http://qudt.org/schema/qudt/QuantityValue> rdfs:subClassOf bedeo:Value .


###  https://csse.utoronto.ca/Account
bedeo:Account rdf:type owl:Class ;
              rdfs:comment "A digital account for use on a digital platform"@en ;
              rdfs:label "Account" .


###  https://csse.utoronto.ca/Address
bedeo:Address rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty bedeo:has_latitude ;
                                owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty bedeo:has_longitude ;
                                owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty bedeo:has_unit_identifier ;
                                owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ;
              rdfs:comment "Information about the location of an entity"@en ;
              rdfs:label "Address"@en .


###  https://csse.utoronto.ca/Agent
bedeo:Agent rdf:type owl:Class ;
            rdfs:subClassOf [ rdf:type owl:Restriction ;
                              owl:onProperty bedeo:has_interest_in ;
                              owl:someValuesFrom bedeo:Asset
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty bedeo:is_beneficiary_of ;
                              owl:someValuesFrom bedeo:Asset
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty bedeo:is_member_of ;
                              owl:someValuesFrom bedeo:Organization
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty bedeo:has_role ;
                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass bedeo:Role
                            ] ;
            rdfs:comment "Something autonomous that can adapt to and interact with its environment"@en ;
            rdfs:label "Agent"@en .


###  https://csse.utoronto.ca/AirSpaceParcel
bedeo:AirSpaceParcel rdf:type owl:Class ;
                     rdfs:subClassOf bedeo:Parcel ;
                     rdfs:comment "A legally defined three-dimensional volume of space"@en ;
                     rdfs:label "Air Space Parcel"@en .


###  https://csse.utoronto.ca/AlbertaLand
bedeo:AlbertaLand rdf:type owl:Class ;
                  rdfs:subClassOf bedeo:Land ;
                  rdfs:comment "Land and the rights to land, as legally defined in Alberta"@en ;
                  rdfs:label "Alberta Land"@en .


###  https://csse.utoronto.ca/AlbertaParcel
bedeo:AlbertaParcel rdf:type owl:Class ;
                    rdfs:subClassOf bedeo:AlbertaLand ,
                                    bedeo:ParcelOfLand ;
                    rdfs:comment "A land parcel, as legally defined in Alberta"@en ;
                    rdfs:label "Alberta Land Parcel"@en .


###  https://csse.utoronto.ca/Application
bedeo:Application rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty bedeo:has_acceptance_status ;
                                    owl:someValuesFrom xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty bedeo:has_application_status ;
                                    owl:someValuesFrom xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty bedeo:has_co-applicant ;
                                    owl:someValuesFrom bedeo:Agent
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty bedeo:has_proposal ;
                                    owl:someValuesFrom bedeo:Proposal
                                  ] ,
