###  https://csse.utoronto.ca/PartnershipOpportunity
bedeo:PartnershipOpportunity rdf:type owl:Class ;
                             rdfs:subClassOf [ rdf:type owl:Restriction ;
                                               owl:onProperty bedeo:has_constraint ;
                                               owl:someValuesFrom bedeo:CharacteristicConstraintClause
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty bedeo:has_need_type ;
                                               owl:someValuesFrom bedeo:PartnershipOpportunityNeed
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty bedeo:has_real_estate_asset ;
                                               owl:someValuesFrom bedeo:real_estate_asset
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty bedeo:has_land ;
                                               owl:allValuesFrom bedeo:Land
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty bedeo:has_partner ;
                                               owl:allValuesFrom bedeo:Agent
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty bedeo:requires_partnership_role ;
                                               owl:allValuesFrom bedeo:RoleType
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty bedeo:has_additional_info ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onClass bedeo:OpportunityAdditionalInfo
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty bedeo:has_primary_contact ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onClass bedeo:Contact
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty bedeo:has_project_stage ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onClass bedeo:ProjectStage
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty bedeo:has_project_type ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onClass bedeo:ProjectType
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty bedeo:has_end_date ;
                                               owl:someValuesFrom xsd:date
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty bedeo:has_start_date ;
                                               owl:someValuesFrom xsd:date
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty bedeo:has_description ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onDataRange xsd:string
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty bedeo:has_name ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onDataRange xsd:string
                                             ] ;
                             rdfs:comment "An opportunity to form a business agreement and operation between two or more individuals and organizations who share the management and profits of a project."@en ;
                             rdfs:label "Partnership opportunity"@en ;
                             <http://www.w3.org/2004/02/skos/core#altLabel> "Opportunity listing"@en .


